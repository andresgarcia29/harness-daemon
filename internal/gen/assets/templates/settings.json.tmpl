{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-direct-push.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-build-slot.sh" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-canonical.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Grep|Glob|Bash|NotebookRead",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/track-read.sh", "async": true }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-emit.sh tool", "async": true }
        ]
      }
    ],
    "SubagentStart": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-emit.sh subagent-start", "async": true } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-emit.sh subagent-stop", "async": true } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-emit.sh stop", "async": true } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-emit.sh prompt", "async": true } ] }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl edit:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(argocd app delete:*)",
      "Bash(argocd app rollback:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(npm test -- -u:*)",
      "Bash(vitest -u:*)",
      "Bash(vitest --update:*)",
      "Bash(pytest --inline-snapshot=fix:*)",
      "Bash(flutter test --update-goldens:*)",
      "Bash(go test -update:*)"
    ]
  },
  "env": {
    "OTEL_RESOURCE_ATTRIBUTES": "harness.project={{PROJECT_SLUG}}"
  }
}
