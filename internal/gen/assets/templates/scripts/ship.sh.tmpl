#!/usr/bin/env bash
# ship.sh — ÚNICA puerta de salida a main. Los agentes piden shippear;
# este script decide. Determinista, cero tokens en el camino verde.
#
# Uso: ship.sh <task-id> <repo>
# Opera sobre el WORKTREE de la tarea (worktrees/<task>/<repo>), nunca
# sobre el clon canónico. Serie solo lo que tiene orden real:
# rebase → trailer → carril. Después, los gates independientes corren EN
# PARALELO (lenguaje+buf ∥ gitleaks+semgrep ∥ tests-no-debilitados ∥
# veredicto+evidencia+policy) y se reportan TODOS los rojos juntos — un
# solo prompt de fix con todo, en vez de descubrirlos ronda por ronda.
# Al final, en serie otra vez: lock → push.
#
# Portabilidad: bash 3.2 (macOS), BSD grep. Sin flock (lock por mkdir).
set -euo pipefail

TASK="${1:?uso: ship.sh <task-id> <repo>}"
REPO="${2:?uso: ship.sh <task-id> <repo>}"
WS="$(cd "$(dirname "$0")/.." && pwd)"
WT="$WS/worktrees/$TASK/$REPO"
BASE="$WS/repos/$REPO"
MAX_RETRY={{LOOP_BUDGET}}
LOCKDIR="$WS/locks/$REPO.lock.d"
mkdir -p "$WS/locks" "$WS/tasks/$TASK"

[ -d "$WT" ] || { echo "❌ no existe el worktree $WT"; echo "   ↳ remediación: scripts/worktree-task.sh $TASK $REPO"; exit 2; }
[ -d "$BASE/.git" ] || { echo "❌ no existe el clon base $BASE"; exit 2; }

# El bus: lo que este gate decide se cuenta. Fail-open — si emit.sh no está,
# ship.sh funciona igual (el bus es observación, no control).
# shellcheck source=/dev/null
[ -f "$WS/scripts/emit.sh" ] && . "$WS/scripts/emit.sh" || emit() { :; }

# Instrumentación en UN solo punto: si estamos empezando un gate, el anterior
# pasó. El trap sabe cuál falló. Cero riesgo de olvidarse de instrumentar uno.
gate() {
  [ -n "${CURRENT_GATE:-}" ] && [ "$CURRENT_GATE" != "preflight" ] \
    && emit gate "$CURRENT_GATE" true
  echo "── gate: $1 ──"; CURRENT_GATE="$1"
}

# El error de un gate es un PROMPT: al fallar cualquier gate, el trap
# imprime la instrucción de autocorrección (el agente que lee esto
# arregla en una iteración, sin adivinar). También libera el lock.
CURRENT_GATE="preflight"; LOCK_HELD=""
on_exit() {
  local rc=$?
  [ -n "$LOCK_HELD" ] && rm -rf "$LOCKDIR"
  if [ "$rc" -eq 0 ]; then
    [ -n "${CURRENT_GATE:-}" ] && emit gate "$CURRENT_GATE" true
    return 0
  fi
  # UN GATE QUE BLOQUEA ES LA MEJOR NOTICIA DEL SISTEMA: es la prueba de que el
  # harness frena a su propio agente. Se cuenta igual de fuerte que un éxito.
  emit gate "$CURRENT_GATE — BLOQUEÓ el ship de $REPO (exit $rc)" false
  echo ""
  echo "⛔ gate '$CURRENT_GATE' falló (exit $rc)."
  echo "   → Lee el error de arriba. Corrige SOLO eso en el worktree $WT,"
  echo "     commitea con el trailer 'Task: $TASK' y re-corre ship.sh."
  echo "   → Presupuesto de autofix: 2 rondas. Si esta es la tercera, PARA"
  echo "     y escala a humano con el error completo (Ley 6)."
}
trap on_exit EXIT

# ── Lock por repo: merge queue de pobre, portable (sin flock) ─────────
# Dos ventanas de muerte que hay que cerrar (las dos costaron un lock inmortal):
#   1. mkdir OK → SIGKILL → pid nunca escrito. El reclamo de huérfanos exigía
#      [ -f pid ], así que un lock sin pid no era reclamable por NADIE: todo
#      ship futuro de ese repo esperaba 10 min y moría, para siempre, hasta que
#      un humano hiciera rm -rf. Reproducido antes de arreglarlo.
#   2. mkdir OK → fallo → el trap corría con LOCK_HELD vacío y no limpiaba.
#      LOCK_HELD se marca AHORA justo después del mkdir, no después del pid.
acquire_lock() {
  local waited=0 nopid=0
  until mkdir "$LOCKDIR" 2>/dev/null; do
    if [ -f "$LOCKDIR/pid" ]; then
      # lock huérfano: el proceso dueño ya no existe
      if ! kill -0 "$(cat "$LOCKDIR/pid" 2>/dev/null)" 2>/dev/null; then
        echo "⚠️  lock huérfano de pid $(cat "$LOCKDIR/pid" 2>/dev/null); lo reclamo"
        rm -rf "$LOCKDIR"; nopid=0; continue
      fi
      nopid=0
    else
      # Sin pid: o el dueño está EN la ventana de adquisición (microsegundos),
      # o murió dentro de ella y el lock quedó inmortal. Damos gracia; si a los
      # 15s sigue sin pid, no hay dueño vivo que lo vaya a escribir.
      nopid=$((nopid+1))
      if [ "$nopid" -ge 15 ]; then
        echo "⚠️  lock sin pid tras 15s — huérfano de una muerte en la ventana de adquisición; lo reclamo"
        rm -rf "$LOCKDIR"; nopid=0; continue
      fi
      sleep 1; continue
    fi
    waited=$((waited+3))
    [ "$waited" -ge 600 ] && { echo "❌ lock de $REPO ocupado >10min ($LOCKDIR) — otro ship en curso"; exit 6; }
    sleep 3
  done
  LOCK_HELD=1                 # ANTES del pid: si morimos ahora, el trap limpia
  echo $$ > "$LOCKDIR/pid"
}

# ── Gates ─────────────────────────────────────────────────────────────
gate_trailer() {
  gate "trailer Task: $TASK"
  local total with_trailer
  total=$(git rev-list --count origin/main..HEAD)
  [ "$total" -gt 0 ] || { echo "❌ no hay commits nuevos sobre origin/main"; exit 3; }
  with_trailer=$(git log origin/main..HEAD --format=%B | grep -cE "^Task: $TASK\$" || true)
  [ "$with_trailer" -ge "$total" ] || {
    echo "❌ $((total-with_trailer)) de $total commits sin trailer 'Task: $TASK'"
    echo "   ↳ remediación: git rebase origin/main --exec 'git commit --amend --no-edit --trailer \"Task: $TASK\"'"
    exit 3
  }
}

# gate_lane — el carril lo declara el intake; el diff lo confirma este gate.
# express prometió: un solo repo (implícito: el worktree ES un repo), cero
# contratos, cero migraciones, cero infra. Si el diff rompe la promesa, el
# ship no pasa: la tarea escala de carril y re-entra por /rfc. Equivocarse
# de carril cuesta una re-entrada — jamás un ship sin la deliberación que
# tocaba. Por esto los carriles no relajan la seguridad: la clasificación
# del intake es una propuesta; este gate es quien la verifica.
gate_lane() {
  gate "carril (lane)"
  local st="$WS/tasks/$TASK/state.json" lane
  lane="$(jq -r '.lane // "full"' "$st" 2>/dev/null || echo full)"
  [ "$lane" = "express" ] || return 0
  local pat="${LANE_GUARD_PATTERN:-(\.proto\$|(^|/)proto/|(^|/)migrations?/|\.sql\$|(^|/)helm/|(^|/)charts/|(^|/)terraform/|(^|/)openapi\.|(^|/)swagger\.)}"
  local hits
  hits="$(git diff origin/main..HEAD --name-only | grep -E "$pat" || true)"
  if [ -n "$hits" ]; then
    echo "❌ carril express, pero el diff toca contratos/migraciones/infra:"
    echo "$hits" | sed 's/^/   · /'
    echo "   ↳ remediación: este cambio SÍ necesita deliberación. Escala el carril:"
    echo "     python3 scripts/harness-policy.py escalate tasks/$TASK --to standard --actor orchestrator"
    echo "     y corre /rfc $TASK — el trabajo hecho se conserva en el worktree."
    exit 3
  fi
}

run_lang_gates() {
  if [ -f go.mod ]; then
    gate go; go vet ./... && go build ./... && go test ./...
  fi
  if [ -f package.json ]; then
    gate ts
    if [ -f tsconfig.json ]; then npx tsc --noEmit; fi   # gate DURO: sin || true
    npm test --if-present
  fi
  if [ -f pyproject.toml ]; then
    gate python
    ruff check .
    if command -v uv >/dev/null; then uv run pytest -q; else pytest -q; fi
  fi
  if [ -f pubspec.yaml ]; then
    gate flutter; flutter analyze && flutter test
  fi
  # Gates de arquitectura y SQL: la CONFIG del repo es el opt-in (sin config,
  # silencio). Con config presente son gates duros — igual que go/ts. Config
  # sin herramienta instalada = warning honesto, no un gate fingido.
  if [ -f .importlinter ] || grep -q '\[tool\.importlinter\]' pyproject.toml 2>/dev/null; then
    if command -v lint-imports >/dev/null; then gate "import-linter"; lint-imports
    else echo "⚠️  config de import-linter presente pero lint-imports no instalado — gate saltado"; fi
  fi
  if [ -f .go-arch-lint.yml ]; then
    if command -v go-arch-lint >/dev/null; then gate "go-arch-lint"; go-arch-lint check
    else echo "⚠️  .go-arch-lint.yml presente pero go-arch-lint no instalado — gate saltado"; fi
  fi
  # squawk: lint de migraciones SQL NUEVAS del diff (las viejas no se re-litigan)
  if command -v squawk >/dev/null; then
    local migs
    migs="$(git diff origin/main..HEAD --name-only --diff-filter=A | grep -E '(^|/)migrations?/.*\.sql$' || true)"
    if [ -n "$migs" ]; then gate "squawk (migraciones)"; squawk $migs; fi
  fi
  if [ -f buf.yaml ]; then
    gate buf
    # breaking: SIEMPRE duro (--against apunta al gitdir del clon base)
    buf breaking --against "$BASE/.git#branch=origin/main"
    # lint: RATCHET — solo violaciones NUEVAS respecto a main bloquean.
    # La deuda preexistente no secuestra shipping ajeno (la baja el
    # ratchet-keeper con su propio ciclo). Se ignoran números de línea
    # para tolerar corrimientos.
    norm() { jq -c 'del(.start_line,.end_line,.start_column,.end_column)' 2>/dev/null | sort; }
    head_lint="$(buf lint --error-format=json 2>/dev/null | norm || true)"
    main_lint="$(cd "$BASE" && buf lint --error-format=json 2>/dev/null | norm || true)"
    new_lint="$(comm -13 <(printf '%s' "$main_lint") <(printf '%s' "$head_lint"))"
    if [ -n "$new_lint" ]; then
      echo "❌ buf lint: violaciones NUEVAS introducidas por este cambio:"
      echo "$new_lint" | jq -r '"   \(.path): \(.message)"' 2>/dev/null || echo "$new_lint"
      echo "   ↳ remediación: corrige SOLO estas (la deuda preexistente de main no bloquea)"
      exit 3
    fi
    [ -n "$main_lint" ] && echo "⚠️  buf lint: $(printf '%s\n' "$main_lint" | grep -c .) violaciones PREEXISTENTES en main (no bloquean; candidatas al ratchet-keeper)"
  fi
}

run_security_gates() {
  gate gitleaks
  # detect sobre el rango real a pushear (protect --staged es no-op aquí)
  gitleaks detect --no-banner --log-opts="origin/main..HEAD"
  if [ -f "$WS/semgrep/rules.yaml" ]; then
    gate semgrep
    semgrep scan --config "$WS/semgrep/rules.yaml" --error --quiet .
  fi
}

# gate_tests_untouched — el gate confía en el test suite; el test suite es un
# archivo que el agente puede editar. Sin este gate, la forma MÁS BARATA de
# pasar a verde no es arreglar el código: es debilitar el test (SWE-Bench+:
# ~31% de parches "exitosos" pasaban por tests débiles).
#
# v2, con las lecciones de campo: (1) cuenta LLAMADAS reales de aserción
# (una línea de import con la palabra expect o un comentario con asserted ya
# no cuentan); (2) contabilidad NETA por archivo: una línea MOVIDA aparece en
# el lado - y en el +, neto 0; un move entre archivos de test (suma global
# <= 0, sin skips ni borrados) pasa con aviso; (3) el escape exige DECLARAR:
# el delta-spec debe nombrar CADA archivo debilitado DENTRO de una sección
# MODIFIED/REMOVED (escribir la palabra en la prosa ya no abre nada).
#
# Residuales conscientes (rúbrica del reviewer, no de este gate): borrar
# filas de una tabla Go table-driven, y reemplazos tautológicos
# (expect(true).toBe(true)). -M explícito en TODOS los git diff: sin él, un
# rename cuenta como D+A según la config diff.renames del usuario.
gate_tests_untouched() {
  gate "tests no debilitados"
  local pat="${TEST_PATH_PATTERN:-(test|spec|Test|_test\.|\.test\.|\.spec\.|/tests?/|/spec/)}"
  local touched
  touched="$(git diff -M origin/main..HEAD --name-status \
    | awk -F'\t' '{ for (i = 2; i <= NF; i++) print $i }' | grep -E "$pat" | sort -u || true)"
  [ -n "$touched" ] || return 0

  local deleted
  deleted="$(git diff -M origin/main..HEAD --diff-filter=D --name-only | grep -E "$pat" || true)"

  # UN pase del diff completo en awk (BSD-safe: sin \b ni \s; gsub cuenta
  # OCURRENCIAS, no líneas). Salida: "<aserciones_netas>\t<skips_netos>\t<archivo>".
  local report
  report="$(git diff -M origin/main..HEAD | TESTPAT="$pat" awk '
    BEGIN {
      pat  = ENVIRON["TESTPAT"]
      asrt = "assert[A-Za-z_]*[[:space:]]*\\(|assert\\.[A-Za-z_]+[[:space:]]*\\(" \
           "|(^|[^A-Za-z0-9_])assert[[:space:]]+[^=[:space:]]" \
           "|expect[[:space:]]*\\(|require\\.[A-Za-z]+\\(" \
           "|t\\.(Error|Fatal|FailNow|Run)|\\.should\\.|@Test" \
           "|(^|[^A-Za-z0-9_.])(it|test|describe)[[:space:]]*\\("
      skp  = "(^|[^A-Za-z0-9_.])(xit|xdescribe|xtest)[[:space:]]*\\(" \
           "|\\.skip[[:space:]]*\\(|\\.only[[:space:]]*\\(|@skip|@unittest\\.skip" \
           "|pytest\\.mark\\.skip|t\\.Skip|#\\[ignore\\]|@Disabled|@Ignore"
      cmnt = "^(//|/\\*|\\*|#[^[]|import[[:space:]]|from[[:space:]])"
    }
    function flush() {
      if (cur != "" && cur ~ pat && (na != 0 || ns != 0))
        printf "%d\t%d\t%s\n", na, ns, cur
      cur = ""; na = 0; ns = 0
    }
    /^diff --git / { flush(); minus = ""; next }
    /^--- /   { minus = $0; sub(/^--- /, "", minus)
                gsub(/^"|"$/, "", minus); sub(/^a\//, "", minus); next }
    /^\+\+\+ / { cur = $0; sub(/^\+\+\+ /, "", cur)
                gsub(/^"|"$/, "", cur); sub(/^b\//, "", cur)
                if (cur == "/dev/null") cur = minus; next }
    /^-/ { l = substr($0, 2); sub(/^[[:space:]]+/, "", l)
           if (l ~ cmnt) next
           if (l ~ skp) ns -= 1
           na += gsub(asrt, "", l); next }
    /^\+/ { l = substr($0, 2); sub(/^[[:space:]]+/, "", l)
            if (l ~ cmnt) next
            if (l ~ skp) ns += 1
            na -= gsub(asrt, "", l); next }
    END { flush() }
  ')"

  # La declaración legítima: contenido BAJO encabezados MODIFIED/REMOVED del
  # delta-spec, y debe nombrar el basename de CADA archivo debilitado.
  local delta="$WS/tasks/$TASK/delta-spec.md" declared=""
  [ -f "$delta" ] && declared="$(awk '
    /^#/ { insec = (toupper($0) ~ /(MODIFIED|REMOVED)/); next }
    insec { print }
  ' "$delta")"
  declares() { printf '%s\n' "$declared" | grep -qiF "$(basename "$1")"; }

  local bad=0 global_na=0 f na ns
  if [ -n "$deleted" ]; then
    while IFS= read -r f; do
      [ -n "$f" ] || continue
      if declares "$f"; then
        echo "   ⚠️  test borrado y DECLARADO en el delta-spec: $f (queda en el registro)"
      else
        echo "   · test BORRADO sin declarar: $f"
        bad=1
      fi
    done <<DELEOF
$deleted
DELEOF
  fi
  if [ -n "$report" ]; then
    while IFS="$(printf '\t')" read -r na ns f; do
      [ -n "$f" ] || continue
      global_na=$((global_na+na))
      [ "$na" -gt 0 ] || [ "$ns" -gt 0 ] || continue
      if declares "$f"; then
        echo "   ⚠️  tests tocados y DECLARADOS en el delta-spec: $f"
        continue
      fi
      [ "$na" -gt 0 ] && echo "   · $f: $na aserciones netas eliminadas"
      [ "$ns" -gt 0 ] && echo "   · $f: $ns skips/only netos añadidos"
      bad=1
    done <<REPEOF
$report
REPEOF
    # move entre archivos de test: neto por archivo != 0 pero global <= 0 y
    # sin skips ni borrados: reorganizar suites es legítimo, no debilitar
    if [ "$bad" -eq 1 ] && [ "$global_na" -le 0 ] && [ -z "$deleted" ] \
       && ! printf '%s\n' "$report" | awk -F'\t' '$2 > 0 { found=1 } END { exit !found }'; then
      echo "   ⚠️  aserciones movidas ENTRE archivos de test (neto global $global_na): no es debilitamiento"
      bad=0
    fi
  fi
  [ "$bad" -eq 0 ] && return 0
  echo "❌ este cambio DEBILITA tests y el delta-spec no lo declara (archivos arriba):"
  echo "   ↳ remediación: los tests son el CONTRATO, no el obstáculo. Si el"
  echo "     comportamiento DEBE cambiar, decláralo en tasks/$TASK/delta-spec.md:"
  echo "     bajo '## MODIFIED Requirements' o '## REMOVED Requirements' la entrada"
  echo "     debe NOMBRAR cada archivo de test afectado. Si no, arregla el CÓDIGO"
  echo "     hasta que el test pase como está."
  exit 3
}

# gate_evidence — nuestra ley es "los agentes proponen, los sistemas
# deterministas verifican". La compliance matrix la ESCRIBE un agente: hasta
# ahora, el verificador proponía. Este gate no juzga el código; solo comprueba
# mecánicamente que el artefacto citado por cada requirement (a) existe y (b)
# fue REALMENTE leído (lo registra el hook track-read.sh). Es una intersección
# de conjuntos: cero LLM, cero opinión.
gate_evidence() {
  local v="$WS/tasks/$TASK/verdict-$REPO.json"
  jq -e 'has("compliance")' "$v" >/dev/null 2>&1 || return 0
  gate "evidencia de compliance"
  local log="$WS/tasks/$TASK/evidence.log"
  local missing=0 unread=0 row art
  while IFS= read -r art; do
    [ -n "$art" ] || continue
    if [ ! -e "$WS/$art" ] && [ ! -e "$WT/$art" ]; then
      echo "   ✗ citado pero NO EXISTE: $art"; missing=$((missing+1)); continue
    fi
    if [ -f "$log" ] && grep -qF -- "$art" "$log"; then :; else
      echo "   ✗ citado pero NADIE LO LEYÓ: $art"; unread=$((unread+1))
    fi
  done <<EOF
$(jq -r '.compliance[]? | select(.covered==true) |
  if (.tests? | type) == "array" then .tests[]
  else (.evidence_path // .test // empty) end' "$v" 2>/dev/null)
EOF
  if [ "$missing" -gt 0 ] || [ "$unread" -gt 0 ]; then
    echo "❌ la compliance matrix cita evidencia que no existe ($missing) o que nunca se leyó ($unread)"
    echo "   ↳ remediación: un requirement solo pasa a covered:true si el reviewer"
    echo "     ABRIÓ el artefacto que lo prueba (test, log, screenshot). Corre el"
    echo "     test, lee su salida, y cita la ruta real en .compliance[].evidence."
    echo "     'Confía en mí' no es evidencia — por eso existe este gate."
    exit 3
  fi
}

check_verdict() {
  gate "veredicto de review"
  local v="$WS/tasks/$TASK/verdict-$REPO.json"
  [ -f "$v" ] || { echo "❌ sin veredicto en $v"; echo "   ↳ remediación: corre /review $TASK $REPO primero"; exit 3; }
  jq -e '.verdict=="pass" and .qa=="pass"' "$v" >/dev/null \
    || { echo "❌ veredicto no es pass — corrige los items blocking listados en $v (cada uno trae su remediación) y re-corre /review"; exit 3; }
  # compliance: todo requirement del delta-spec cubierto por tests
  jq -e '(.requirements_uncovered // 0) == 0' "$v" >/dev/null \
    || { echo "❌ $(jq -r '.requirements_uncovered' "$v") requirements del delta-spec sin test que los proteja"
         echo "   ↳ remediación: escribe el test faltante (ver .compliance[] con covered:false en $v) o pide al humano una excepción explícita"; exit 3; }
}

# El veredicto no es una afirmación libre: policy v1 comprueba estado, rondas
# y separación de roles; evidence v1 liga cada resultado al HEAD exacto y al
# hash de su salida. Ambos validadores son stdlib Python y fail-closed.
gate_policy_and_evidence() {
  gate "policy + evidencia v1"
  local v="$WS/tasks/$TASK/verdict-$REPO.json"
  local head
  head="$(git rev-parse HEAD)"
  python3 "$WS/scripts/harness-policy.py" --policy "$WS/harness-policy.json" \
    validate-ship "$WS/tasks/$TASK" --commit "$head" --verdict "$v"
  python3 "$WS/scripts/evidence.py" verify \
    --task-dir "$WS/tasks/$TASK" --repo "$REPO" --commit "$head" \
    --verdict "$v" --require-kind test
}

# ── Gates en paralelo ─────────────────────────────────────────────────
# Los grupos no comparten orden real entre sí (cada uno es read-only sobre
# el worktree o corre su propia toolchain); DENTRO de un grupo el orden se
# conserva (check_verdict antes que evidence). Cada grupo corre en subshell
# con su propio CURRENT_GATE y escribe su exit a un archivo: un rojo no
# oculta a los demás, y el implementer recibe TODOS los errores en un solo
# prompt de fix en vez de descubrirlos ronda por ronda.
GDIR=""; PAR_PIDS=""; PAR_SLOTS=""
par() {  # par <slot> <gate-fn>... — corre un grupo de gates en background
  local slot="$1"; shift
  (
    # PAR_SLOT: copia a scope de subshell. El trap EXIT de un subshell que
    # muere por set -e corre DESPUÉS de desmontar los locals de la función
    # (bash 3.2 y 5.x): referenciar $slot ahí es unbound variable.
    PAR_SLOT="$slot"
    CURRENT_GATE=""
    group_exit() {
      local rc=$?
      if [ "$rc" -eq 0 ]; then
        [ -n "${CURRENT_GATE:-}" ] && emit gate "$CURRENT_GATE" true
      else
        emit gate "$CURRENT_GATE — BLOQUEÓ el ship de $REPO (exit $rc)" false
        echo "⛔ gate '$CURRENT_GATE' falló (exit $rc)"
      fi
      echo "$rc" > "$GDIR/$PAR_SLOT.rc"
    }
    trap group_exit EXIT
    local fn; for fn in "$@"; do "$fn"; done
  ) > "$GDIR/$slot.out" 2>&1 &
  PAR_PIDS="$PAR_PIDS $!"
  PAR_SLOTS="$PAR_SLOTS $slot"
}

run_parallel_gates() {
  # cierra el gate serial anterior (mismo contrato que gate())
  [ -n "${CURRENT_GATE:-}" ] && [ "$CURRENT_GATE" != "preflight" ] \
    && emit gate "$CURRENT_GATE" true
  CURRENT_GATE=""
  GDIR="$(mktemp -d "${TMPDIR:-/tmp}/ship-gates.XXXXXX")"
  PAR_PIDS=""; PAR_SLOTS=""
  echo "── gates en paralelo: lang ∥ security ∥ tests ∥ veredicto ──"
  par lang      run_lang_gates
  par security  run_security_gates
  par tests     gate_tests_untouched
  par veredicto check_verdict gate_evidence gate_policy_and_evidence
  local pid; for pid in $PAR_PIDS; do wait "$pid" 2>/dev/null || true; done
  local slot rc failed=""
  for slot in $PAR_SLOTS; do
    cat "$GDIR/$slot.out"
    rc="$(cat "$GDIR/$slot.rc" 2>/dev/null || echo 1)"
    [ "$rc" -eq 0 ] || failed="$failed $slot"
  done
  rm -rf "$GDIR"
  if [ -n "$failed" ]; then
    CURRENT_GATE="gates paralelos:$failed"
    echo "❌ gates rojos:$failed — TODOS los errores están arriba. Corrige TODO"
    echo "   en UNA iteración (cada gate trae su remediación) y re-corre ship.sh."
    exit 3
  fi
}

# ── Loop de ship ──────────────────────────────────────────────────────
acquire_lock
cd "$WT"
attempt=0
while [ "$attempt" -lt "$MAX_RETRY" ]; do
  attempt=$((attempt+1))
  echo "══ ship $REPO (task $TASK) intento $attempt/$MAX_RETRY ══"
  git fetch origin
  git rebase origin/main || { git rebase --abort; echo "❌ conflicto de rebase — resuélvelo en el worktree $WT"; exit 4; }
  gate_trailer
  gate_lane
  run_parallel_gates
  if git push origin HEAD:main; then
    sha="$(git rev-parse --short HEAD)"
    echo "{\"repo\":\"$REPO\",\"sha\":\"$sha\",\"shipped_at\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}" >> "$WS/tasks/$TASK/ship.log"
    # Cierra el último gate ANTES de anunciar el ship: si lo dejara al trap,
    # el "veredicto ✅" saldría en el bus DESPUÉS del "shippeé" y la historia
    # tendría el penúltimo paso después del último.
    [ -n "${CURRENT_GATE:-}" ] && emit gate "$CURRENT_GATE" true && CURRENT_GATE=""
    emit ship "$REPO @ $sha — pasó los gates y está en main" true
    echo "✅ shipped $REPO @ $sha"
    echo "→ siguiente: scripts/deploy-watch.sh $TASK $REPO (o /ship se encarga)"
    exit 0
  fi
  echo "⚠️ push rechazado (non-fast-forward), reintentando tras rebase…"
done
echo "❌ agotados $MAX_RETRY intentos — escala a humano"
exit 5
