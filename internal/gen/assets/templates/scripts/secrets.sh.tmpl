#!/usr/bin/env bash
# secrets.sh — materializa secretos desde {{SECRETS_SOURCE}} hacia ./.secrets
# (KEY=VALUE, gitignoreado) y derivados multilínea en ./.secrets.d/.
# El repo NUNCA contiene valores; este archivo solo contiene REFERENCIAS.
#
# Uso: secrets.sh pull | secrets.sh check
set -euo pipefail
WS="$(cd "$(dirname "$0")/.." && pwd)"
OUT="$WS/.secrets"; OUTD="$WS/.secrets.d"
CMD="${1:-pull}"

# ── fuente: vault ─────────────────────────────────────────────────────
# Token periódico en ~/.config/harness/vault-token (chmod 600, fuera del
# repo). Policies mínimas: read del KV del harness; write solo app-plane.
pull_vault() {
  export VAULT_ADDR="{{VAULT_ADDR}}"
  local tokfile="$HOME/.config/harness/vault-token"
  [ -f "$tokfile" ] || { echo "❌ falta $tokfile (token periódico de Vault, chmod 600)"; exit 1; }
  VAULT_TOKEN="$(cat "$tokfile")"; export VAULT_TOKEN
  vault token renew >/dev/null 2>&1 || echo "⚠️  no pude renovar el token (¿expiró?)"

  : > "$OUT"; chmod 600 "$OUT"; mkdir -p "$OUTD"
  echo "VAULT_ADDR=$VAULT_ADDR" >> "$OUT"
  echo "VAULT_TOKEN=$VAULT_TOKEN" >> "$OUT"
  # Cada línea: <ENV_KEY> <kv-path> <campo>. Editar según el layout real.
{{VAULT_KEYS}}
#  dump_kv GH_TOKEN            {{VAULT_KV_BASE}}/github  pat
#  dump_kv ARGOCD_AUTH_TOKEN   {{VAULT_KV_BASE}}/argocd  token
#  dump_kv KARGO_TOKEN         {{VAULT_KV_BASE}}/kargo   token
#  dump_file kubeconfig        {{VAULT_KV_BASE}}/kubeconfig value   # → .secrets.d/kubeconfig
  finish
}

MISSED=0
dump_kv() { # dump_kv <ENV_KEY> <kv-path> <campo>
  local v; v="$(vault kv get -field="$3" "$2" 2>/dev/null)" \
    || { echo "⚠️  no pude leer de Vault: $2 ($3)"; MISSED=$((MISSED+1)); return 0; }
  echo "$1=$v" >> "$OUT"
}

dump_file() { # dump_file <archivo> <kv-path> <campo> — multilínea → .secrets.d/
  vault kv get -field="$3" "$2" > "$OUTD/$1" 2>/dev/null \
    && chmod 600 "$OUTD/$1" || { echo "⚠️  no pude leer de Vault: $2 ($3)"; MISSED=$((MISSED+1)); }
}

# ── fuente: gcp secret manager ────────────────────────────────────────
pull_gcp_sm() {
  : > "$OUT"; chmod 600 "$OUT"
  # Cada línea: <ENV_KEY> <secret-name>. Editar según el proyecto.
{{GCP_SM_KEYS}}
#  dump_sm GH_TOKEN gh-harness-token
  echo "✅ secretos materializados en $OUT"
}
dump_sm() {
  local v; v="$(gcloud secrets versions access latest --secret="$2" 2>/dev/null)" \
    || { echo "⚠️  falta en Secret Manager: $2"; return 0; }
  echo "$1=$v" >> "$OUT"
}

# ── fuente: aws secrets manager ───────────────────────────────────────
pull_aws_sm() {
  : > "$OUT"; chmod 600 "$OUT"
  # Cada línea: <ENV_KEY> <secret-id>. Editar según la cuenta.
{{AWS_SM_KEYS}}
#  dump_asm GH_TOKEN harness/github-token
  finish
}
dump_asm() {
  local v; v="$(aws secretsmanager get-secret-value --secret-id "$2" --query SecretString --output text 2>/dev/null)" \
    || { echo "⚠️  no pude leer de AWS SM: $2"; MISSED=$((MISSED+1)); return 0; }
  echo "$1=$v" >> "$OUT"
}

# ── fuente: doppler (proyecto/config del directorio) ──────────────────
pull_doppler() {
  doppler secrets download --no-file --format env > "$OUT" 2>/dev/null \
    && { chmod 600 "$OUT"; echo "✅ secretos materializados en $OUT (doppler)"; } \
    || { echo "❌ doppler falló — ¿doppler login / doppler setup?"; exit 1; }
}

# ── fuente: sops (archivo cifrado versionado) ─────────────────────────
pull_sops() {
  local enc="{{SOPS_FILE}}"   # ej. secrets.enc.env
  [ -f "$enc" ] || { echo "❌ no existe $enc"; exit 1; }
  sops -d "$enc" > "$OUT" 2>/dev/null \
    && { chmod 600 "$OUT"; echo "✅ secretos materializados en $OUT (sops)"; } \
    || { echo "❌ sops no pudo descifrar — ¿tienes la llave (age/KMS)?"; exit 1; }
}

# ── fuente: 1password (plantilla con referencias op://) ───────────────
pull_op() {
  local tpl=".secrets.tpl"    # KEY=op://vault/item/field, versionable
  [ -f "$tpl" ] || { echo "❌ no existe $tpl (plantilla con refs op://)"; exit 1; }
  op inject -i "$tpl" -o "$OUT" 2>/dev/null \
    && { chmod 600 "$OUT"; echo "✅ secretos materializados en $OUT (1password)"; } \
    || { echo "❌ op inject falló — ¿op signin?"; exit 1; }
}

# ── fuente: env (sin materialización; .secrets lo escribe el humano) ──
pull_env() {
  [ -f "$OUT" ] && echo "✅ .secrets ya existe (fuente: env — lo mantienes a mano)" \
    || { echo "❌ crea $OUT a mano (KEY=VALUE, chmod 600); ver secrets.refs en harness-answers.yaml"; exit 1; }
}

finish() {
  if [ "$MISSED" -eq 0 ]; then echo "✅ secretos materializados en $OUT"; else
    echo "❌ materialización INCOMPLETA: $MISSED claves no se pudieron leer"
    echo "   ↳ causa típica: token/credencial expirada o layout distinto"; exit 1
  fi
}

# Despacho por VALOR de la fuente, no por nombre de función interpolado.
# Antes el case llamaba a "pull_" + un placeholder con el nombre de la
# función, y bastaba con que el generador inyectara "pull_vault" en vez de
# "vault" para producir "pull_pull_vault: command not found" en TODA
# instalación fresca (issue #21): sin .secrets no hay credenciales para nada,
# y el error ni siquiera dice qué placeholder salió mal.
# Aquí el generador solo inyecta el mismo valor que ya escribió en
# harness-answers.yaml, los alias históricos siguen resolviendo, y una fuente
# desconocida falla nombrándose en vez de morir como comando inexistente.
SECRETS_SOURCE="{{SECRETS_SOURCE}}"
pull_dispatch() {
  local s="${SECRETS_SOURCE#pull_}"   # tolera generadores que inyectan la función
  case "$s" in
    vault)                              pull_vault ;;
    gcp-secret-manager|gcp_sm|gcp-sm)   pull_gcp_sm ;;
    aws-secrets-manager|aws_sm|aws-sm)  pull_aws_sm ;;
    doppler)                            pull_doppler ;;
    sops)                               pull_sops ;;
    1password|op|onepassword)           pull_op ;;
    env)                                pull_env ;;
    *)
      echo "❌ fuente de secretos desconocida: '$SECRETS_SOURCE'"
      echo "   ↳ válidas: vault | gcp-secret-manager | aws-secrets-manager | doppler | sops | 1password | env"
      echo "     corrige secrets.source en harness-answers.yaml y re-genera este script (/harness-init .)"
      exit 1 ;;
  esac
}

case "$CMD" in
  pull)  pull_dispatch ;;
  check) [ -f "$OUT" ] && echo "✅ .secrets presente" || { echo "❌ sin .secrets — corre: scripts/secrets.sh pull"; exit 1; } ;;
  *) echo "uso: secrets.sh pull|check"; exit 1 ;;
esac
