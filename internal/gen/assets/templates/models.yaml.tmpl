# models.yaml: LA única perilla de modelos del harness.
#
# Tres niveles, del más simple al más fino (nunca tocas agentes a mano):
#   · cambiar un rol      → edita `roles:` y corre `make models`
#   · un agente puntual   → una línea en `overrides:` y `make models`
#   · una sola tarea      → /auto <id> --model <alias>   (o `model:` en el
#                           frontmatter de tasks/<id>/task.md)
#
# TODO el harness habla en ALIASES (fast | smart | deep). El proveedor los
# traduce a IDs reales: cambiar de proveedor es cambiar UNA línea
# (`provider:`); roles, overrides y comandos no se tocan.
# `scripts/stamp-models.sh` materializa esta política en el frontmatter de
# .claude/agents/ (determinista, $0 tokens); `make models` es su atajo.
#
# FORMATO ESTRICTO (lo parsea awk, sin dependencias): secciones a columna 0,
# claves con DOS espacios de indentación, `clave: valor`. Sin anidación extra.

provider: {{MODEL_PROVIDER}}   # anthropic | vertex | bedrock | kimi | openrouter

# ── alias → id, por proveedor ─────────────────────────────────────────
# anthropic usa los nombres cortos que Claude Code entiende nativo. Los
# demás son EJEMPLOS de formato: verifica el ID exacto en el catálogo de
# tu proveedor antes de cambiar `provider:` (los IDs de Vertex llevan
# @fecha; los de Bedrock, prefijo de región y sufijo de versión).

models.anthropic:
  fast: haiku
  smart: sonnet
  deep: opus

models.vertex:
  # Claude vía Google Vertex. Claude Code: export CLAUDE_CODE_USE_VERTEX=1,
  # ANTHROPIC_VERTEX_PROJECT_ID=<proyecto>, CLOUD_ML_REGION=<región>.
  fast: claude-haiku-4-5@20251001
  smart: claude-sonnet-5@20250929
  deep: claude-opus-4-8@20260120

models.bedrock:
  # Claude vía AWS Bedrock. Claude Code: export CLAUDE_CODE_USE_BEDROCK=1.
  fast: us.anthropic.claude-haiku-4-5-20251001-v1:0
  smart: us.anthropic.claude-sonnet-5-20250929-v1:0
  deep: us.anthropic.claude-opus-4-8-20260120-v1:0

models.kimi:
  # Kimi Code / Moonshot (API compatible con Anthropic).
  fast: kimi-k2-turbo
  smart: kimi-k2
  deep: kimi-k2-thinking

models.openrouter:
  fast: anthropic/claude-haiku-4.5
  smart: anthropic/claude-sonnet-5
  deep: anthropic/claude-opus-4.8

# ── rol → alias ───────────────────────────────────────────────────────
# Principio (sandwich de razonamiento): el gasto en razonamiento es
# proporcional al FAN-OUT del artefacto: una spec o un plan lo leen N
# agentes aguas abajo (deep); un diff lo lee uno (smart); un digest no
# lo lee nadie dos veces (fast). Aquí van ALIASES, nunca IDs crudos.

roles:
  orquestador: {{MODEL_ARCHITECT}}
  architect: {{MODEL_ARCHITECT}}
  abogados: {{MODEL_ARCHITECT}}
  reviewer: {{MODEL_REVIEWER}}
  implementer: {{MODEL_IMPLEMENTER}}
  qa: {{MODEL_IMPLEMENTER}}
  mechanical: {{MODEL_MECHANICAL}}
  escalation: {{MODEL_ESCALATION}}

# ── excepciones por agente ────────────────────────────────────────────
# Una línea por excepción: <archivo de .claude/agents/ sin .md>: <alias>.
# Gana sobre el rol. Ej.:
#   svc-atlas: smart
#   qa: fast
overrides:

# ── escalación (la aplica el comando que orquesta; ver /implement) ────
# El implementer sube a roles.escalation cuando:
#   · 1 veredicto fail cuyo blocking revele comprensión equivocada del
#     problema (no un detalle mecánico); cada ronda extra con el modelo
#     equivocado son 10-20 min de wall-clock
#   · 2 veredictos fail consecutivos en la misma tarea (de cualquier tipo)
#   · un watchdog lo mató por falta de heartbeat
#   · la tarea toca >1 lenguaje o migra un contrato proto
#   · el plan la marcó complexity: high
# El reviewer sube a roles.architect si el diff supera ~400 líneas y no
# se pudo rebanar. Regla dura: escalar modelo NUNCA sustituye escalar a
# humano cuando el presupuesto de loop ({{LOOP_BUDGET}}) se agota.

# ── cronjobs (headless: claude -p --model <id> --effort <e>) ──────────
# tier → alias; cron-runner resuelve el ID con stamp-models.sh.
# fast = detectar/redactar · smart = arreglar acotado · deep = escribir
# tests/reglas nuevas (lo más difícil de hacer bien).

cronjobs:
  cheap: {{MODEL_MECHANICAL}}
  medium: {{MODEL_IMPLEMENTER}}
  expensive: {{MODEL_ESCALATION}}

cronjob_effort:
  cheap: low
  medium: medium
  expensive: high

# Presupuestos por invocación headless (USD). El cron-runner los pasa
# como --max-budget-usd y registra el gasto real en el ledger.
budgets:
  cheap: 1
  medium: 3
  expensive: 8
