# models.yaml: LA única perilla de modelos del harness.
#
# Tres niveles, del más simple al más fino (nunca tocas agentes a mano):
#   · cambiar un rol      → edita `roles:` y corre `make models`
#   · un agente puntual   → una línea en `overrides:` y `make models`
#   · una sola tarea      → /auto <id> --model <alias>   (o `model:` en el
#                           frontmatter de tasks/<id>/task.md)
#
# TODO el harness habla en ALIASES (fast | smart | deep). El proveedor los
# traduce a IDs reales: cambiar de proveedor es cambiar UNA línea
# (`provider:`); roles, overrides y comandos no se tocan.
# `scripts/stamp-models.sh` materializa esta política en el frontmatter de
# .claude/agents/ (determinista, $0 tokens); `make models` es su atajo.
#
# FORMATO ESTRICTO (lo parsea awk, sin dependencias): secciones a columna 0,
# claves con DOS espacios de indentación, `clave: valor`. Sin anidación extra.

provider: {{MODEL_PROVIDER}}   # anthropic | vertex | bedrock | kimi | openrouter

# ── la semántica de los tres aliases ──────────────────────────────────
# deep  = EL PENSADOR. Donde el output es razonamiento con fan-out: el
#         plan, la síntesis del RFC, los litigios, los ADRs, la
#         escalación de un atasco. Su texto lo consumen N agentes.
# smart = EL PRODUCTOR. Todo el token-consuming de crear: implementar,
#         revisar diffs, ejercitar QA, escribir tests y reglas.
# fast  = LO ESPECIFICÍSIMO. Solo tareas sin juicio ni fan-out: digest
#         diario, triage de labels, limpieza mecánica. En duda, smart.

# ── REGLAS DE USO DE FABLE (el tier deep en anthropic) ────────────────
# 1. Fable piensa, no teclea. Va donde la salida es UN artefacto de
#    razonamiento que multiplica (plan, RFC, ADR, veredicto de
#    escalación). Jamás en el loop de edición del implementer: ahí el
#    valor está en el diff y Opus produce igual con menos latencia.
# 2. La escalación SUBE a Fable para RE-PENSAR, no para teclear más:
#    un implementer atascado dos veces no necesita más velocidad,
#    necesita otro enfoque. Al destrabarse, el relevo vuelve a smart.
# 3. Fable rinde con contexto CURADO: specs, briefs y el grafo, no
#    dumps de código (eso ya es ley del harness: repo-brief, graphify).
# 4. No lo pongas en cronjobs baratos ni en QA: pensar donde no hay
#    decisión es latencia comprada. El sandwich existe para eso.

# ── alias → id, por proveedor ─────────────────────────────────────────
# anthropic usa los nombres cortos que Claude Code entiende nativo. Los
# demás son EJEMPLOS de formato: verifica el ID exacto en el catálogo de
# tu proveedor antes de cambiar `provider:` (Vertex agrega sufijo
# @fecha; Bedrock, prefijo de región y sufijo de versión).

models.anthropic:
  fast: sonnet
  smart: opus
  deep: fable

models.vertex:
  # Claude vía Google Vertex. Claude Code: export CLAUDE_CODE_USE_VERTEX=1,
  # ANTHROPIC_VERTEX_PROJECT_ID=<proyecto>, CLOUD_ML_REGION=<región>.
  # AGREGA el sufijo @fecha que liste TU catálogo de Vertex (Model Garden).
  fast: claude-sonnet-5
  smart: claude-opus-4-8
  deep: claude-fable-5

models.bedrock:
  # Claude vía AWS Bedrock. Claude Code: export CLAUDE_CODE_USE_BEDROCK=1.
  # Verifica el ID exacto (región y sufijo de versión) en tu consola.
  fast: us.anthropic.claude-sonnet-5-20250929-v1:0
  smart: us.anthropic.claude-opus-4-8-20260120-v1:0
  deep: us.anthropic.claude-fable-5-v1:0

models.kimi:
  # Kimi Code / Moonshot (API compatible con Anthropic): thinking piensa,
  # k2 produce, turbo despacha lo mecánico. Misma semántica de tiers.
  fast: kimi-k2-turbo
  smart: kimi-k2
  deep: kimi-k2-thinking

models.minimax:
  # MiniMax (API compatible con Anthropic). Publica un flagship a la vez:
  # verifica el nombre vigente en su catálogo antes de activarlo.
  fast: MiniMax-M2
  smart: MiniMax-M2.1
  deep: MiniMax-M2.1

models.openrouter:
  fast: anthropic/claude-sonnet-5
  smart: anthropic/claude-opus-4.8
  deep: anthropic/claude-fable-5

# ── rol → alias ───────────────────────────────────────────────────────
# El sandwich con nombres propios (anthropic): FABLE planea y arbitra,
# OPUS 4.8 produce todo el código y los veredictos, SONNET despacha lo
# especificísimo. Aquí van ALIASES, nunca IDs crudos.

roles:
  orquestador: {{MODEL_ARCHITECT}}
  architect: {{MODEL_ARCHITECT}}
  abogados: {{MODEL_ARCHITECT}}
  reviewer: {{MODEL_REVIEWER}}
  implementer: {{MODEL_IMPLEMENTER}}
  qa: {{MODEL_IMPLEMENTER}}
  mechanical: {{MODEL_MECHANICAL}}
  escalation: {{MODEL_ESCALATION}}
  # reader: el tier que LEE contexto largo para que el deep razone sobre el
  # destilado, no sobre el volcado crudo (patrón MinionS, arXiv:2502.15964:
  # un modelo barato lee, uno caro razona; hasta 5.7× menos costo con 97.9%
  # de la calidad). OPT-IN: solo se usa si context_distill=true en
  # harness-answers.yaml (PROPUESTO; docs/harness/minions-context-distill.md). Default = fast.
  reader: {{MODEL_MECHANICAL}}

# ── excepciones por agente ────────────────────────────────────────────
# Una línea por excepción: <archivo de .claude/agents/ sin .md>: <alias>.
# Gana sobre el rol. Ej.:
#   svc-atlas: smart
#   qa: fast
overrides:

# ── escalación (la aplica el comando que orquesta; ver /implement) ────
# El implementer sube a roles.escalation cuando:
#   · 1 veredicto fail cuyo blocking revele comprensión equivocada del
#     problema (no un detalle mecánico); cada ronda extra con el modelo
#     equivocado son 10-20 min de wall-clock
#   · 2 veredictos fail consecutivos en la misma tarea (de cualquier tipo)
#   · un watchdog lo mató por falta de heartbeat
#   · la tarea toca >1 lenguaje o migra un contrato proto
#   · el plan la marcó complexity: high
# El reviewer sube a roles.architect si el diff supera ~400 líneas y no
# se pudo rebanar. Regla dura: escalar modelo NUNCA sustituye escalar a
# humano cuando el presupuesto de loop ({{LOOP_BUDGET}}) se agota.

# ── cronjobs (headless: claude -p --model <id> --effort <e>) ──────────
# tier → alias; cron-runner resuelve el ID con stamp-models.sh.
# fast = detectar/redactar · smart = arreglar acotado · deep = escribir
# tests/reglas nuevas (lo más difícil de hacer bien).

cronjobs:
  cheap: {{MODEL_MECHANICAL}}
  medium: {{MODEL_IMPLEMENTER}}
  expensive: {{MODEL_ESCALATION}}

cronjob_effort:
  cheap: low
  medium: medium
  expensive: high

# Presupuestos por invocación headless (USD). El cron-runner los pasa
# como --max-budget-usd y registra el gasto real en el ledger.
budgets:
  cheap: 1
  medium: 3
  expensive: 8
