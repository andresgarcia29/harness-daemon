# Makefile — interfaz humana del harness de {{PROJECT_NAME}}.
# Los agentes usan los scripts/comandos directamente; esto es para ti.
.DEFAULT_GOAL := help

help: ## esta ayuda
	@grep -E '^[a-zA-Z_-]+:.*## ' $(MAKEFILE_LIST) | awk -F':.*## ' '{printf "  \033[36m%-14s\033[0m %s\n", $$1, $$2}'

init: ## onboarding de una pasada: deps + token + secretos + doctor
	@bash scripts/bootstrap.sh

doctor: ## salud del harness (CLIs, MCPs, hooks, links, secretos)
	@bash scripts/doctor.sh .

secrets: ## materializa secretos ({{SECRETS_SOURCE}} → .secrets)
	@bash scripts/secrets.sh pull

models: ## re-estampa los agentes desde models.yaml (edítalo y corre esto)
	@bash scripts/stamp-models.sh

pull: ## todos los repos al último main, en paralelo (--rebase) + grafo
	@bash scripts/pull-all.sh

skills: ## sincroniza la capa compartida de skills (skills.yaml)
	@bash scripts/skills-sync.sh

graph: ## construye/refresca el grafo de graphify (incremental por HEADs)
	@bash scripts/graph-refresh.sh

wt: ## crea worktrees: make wt TASK=<id> REPOS="a b"
	@bash scripts/worktree-task.sh $(TASK) $(REPOS)

wt-rm: ## quita worktrees de una tarea: make wt-rm TASK=<id>
	@bash scripts/worktree-task.sh --rm $(TASK)

gowork: ## loop nativo Go: regenera go.work: make gowork [TASK=<id>]
	@bash scripts/gowork.sh $(TASK)

py: ## loop nativo Python (uv): make py CMD='sync' [REPO=<repo>] [TASK=<id>]
	@bash scripts/py.sh "$(CMD)" "$(REPO)" "$(TASK)"

fe: ## loop nativo frontend: make fe CMD='install' [REPO=<repo>] [TASK=<id>]
	@bash scripts/fe.sh "$(CMD)" "$(REPO)" "$(TASK)"

precheck: ## gates mecánicos sin push (antes de review): make precheck TASK=<id> REPO=<repo>
	@bash scripts/ship.sh --precheck $(TASK) $(REPO)

plan-lint: ## el plan es ejecutable o no es plan: make plan-lint TASK=<id>
	@bash scripts/plan-lint.sh $(TASK)

ship: ## gates + push: make ship TASK=<id> REPO=<repo>
	@bash scripts/ship.sh $(TASK) $(REPO)

watch: ## vigila el deploy: make watch TASK=<id> REPO=<repo>
	@bash scripts/with-secrets.sh bash scripts/deploy-watch.sh $(TASK) $(REPO)

bug: ## verifica y reporta un bug del harness upstream: make bug ARGS='--title … --file … --repro … --impact … --dry-run'
	@bash scripts/harness-bug.sh report $(ARGS)

bugs: ## lo ya reportado upstream desde esta instancia
	@bash scripts/harness-bug.sh list

usage: ## costo por sesión/tarea (ccusage, la báscula oficial)
	@ccusage

ui: ## panel oficial en primer plano (127.0.0.1:7180; PORT=n cambia el puerto): agentes, fases, tokens, terminales
	@harness ui $(if $(PORT),--port $(PORT))

ui-bg: ## panel en background (para VPS/ssh): arranca el daemon y sale; make ui-stop lo baja
	@harness ui -d $(if $(PORT),--port $(PORT)) && echo "→ panel en http://127.0.0.1:$(if $(PORT),$(PORT),7180)"

ui-stop: ## baja el daemon del panel
	@fuser -k $(if $(PORT),$(PORT),7180)/tcp 2>/dev/null && echo "panel detenido" || echo "no había panel corriendo"

.PHONY: help init doctor secrets wt wt-rm gowork py fe ship watch bug bugs usage ui ui-bg ui-stop
