#    url: git@github.com:org/atlas.git
#    branch: main
#    kind: service
#    agent: svc-atlas
#  - name: terraform-core
#    url: git@github.com:org/terraform-core.git
#    branch: main
#    kind: infra-module
#    agent: infra

# DAG de shipping (dependencias primero). Referencia del arquitecto.
dag:
{{DAG_LIST}}
