{
  "schema": 1,
  "workflow": {
    "initial_phase": "intake",
    "allowed_transitions": {
      "intake": [
        "rfc"
      ],
      "rfc": [
        "implement"
      ],
      "implement": [
        "review"
      ],
      "review": [
        "implement",
        "ship"
      ],
      "ship": [
        "deploy"
      ],
      "deploy": [
        "archive"
      ],
      "archive": [],
      "blocked": []
    },
    "lanes": {
      "express": {
        "allowed_transitions": {
          "intake": [
            "implement"
          ],
          "implement": [
            "review"
          ],
          "review": [
            "implement",
            "ship"
          ],
          "ship": [
            "deploy"
          ],
          "deploy": [
            "archive"
          ],
          "archive": [],
          "blocked": []
        }
      },
      "standard": {},
      "full": {}
    },
    "lane_escalation": [
      "express",
      "standard",
      "full"
    ],
    "allowed_pause_reasons": [
      "draft_constitution",
      "irreversible_architecture",
      "adr_conflict",
      "rfc_no_convergence",
      "loop_budget_exhausted",
      "gate_autofix_exhausted",
      "deploy_failed",
      "prompt_injection",
      "requested_boundary",
      "custom_step_failed"
    ]
  },
  "limits": {
    "max_review_rounds": 3
  },
  "ship": {
    "require_independent_review": true,
    "require_fresh_evidence": true,
    "required_evidence_kinds": [
      "test"
    ]
  }
}
